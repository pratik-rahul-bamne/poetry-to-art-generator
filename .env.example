# AI Poem Visualizer — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── AI Providers ──────────────────────────────────────────────────────────────
# Get your free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# NLP Provider: gemini | local (FLAN-T5) | fallback (keyword-based)
NLP_PROVIDER=gemini

# Image Provider: pollinations | stable-diffusion | huggingface
IMAGE_PROVIDER=pollinations

# HuggingFace token (optional, for HF inference API)
HF_API_TOKEN=

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default): leave as is
# PostgreSQL: postgresql://user:password@localhost:5432/poem_visualizer
DATABASE_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GUEST=10
RATE_LIMIT_REGISTERED=50

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: ["*"]
# Production: ["https://your-domain.com"]
ALLOWED_ORIGINS=["*"]
